{
  "name": "codebrain-vscode",
  "displayName": "CodeBrain",
  "description": "Graph-powered code intelligence for Copilot. Auto-setup, auto-index, MCP config, and PR review.",
  "version": "0.1.0",
  "publisher": "codebrain",
  "license": "MIT",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "icon": "resources/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "codebrain.setup",
        "title": "Setup CodeBrain",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.installCli",
        "title": "Install CodeBrain CLI",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.analyze",
        "title": "Analyze Repo",
        "category": "CodeBrain",
        "icon": "$(graph-line)"
      },
      {
        "command": "codebrain.analyzeForce",
        "title": "Force Re-index",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.status",
        "title": "Show Index Status",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.openDashboard",
        "title": "Open Graph Dashboard",
        "category": "CodeBrain",
        "icon": "$(graph)"
      },
      {
        "command": "codebrain.listRepos",
        "title": "List Indexed Repos",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.clean",
        "title": "Clean Index",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.cleanAll",
        "title": "Clean All Indexes",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.serve",
        "title": "Start Web UI Bridge Server",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.generateWiki",
        "title": "Generate Wiki",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.query",
        "title": "Query Knowledge Graph",
        "category": "CodeBrain",
        "icon": "$(search)"
      },
      {
        "command": "codebrain.prReview",
        "title": "PR Review with CodeBrain",
        "category": "CodeBrain",
        "icon": "$(git-pull-request-review)"
      },
      {
        "command": "codebrain.refreshTreeView",
        "title": "Refresh",
        "category": "CodeBrain",
        "icon": "$(refresh)"
      },
      {
        "command": "codebrain.selectRepo",
        "title": "Select Repository",
        "category": "CodeBrain",
        "icon": "$(repo)"
      },
      {
        "command": "codebrain.selectGroup",
        "title": "Select Group",
        "category": "CodeBrain",
        "icon": "$(server)"
      },
      {
        "command": "codebrain.createGroup",
        "title": "Create Repository Group",
        "category": "CodeBrain",
        "icon": "$(add)"
      },
      {
        "command": "codebrain.syncGroup",
        "title": "Sync Group",
        "category": "CodeBrain",
        "icon": "$(sync)"
      },
      {
        "command": "codebrain.clearContext",
        "title": "Clear Active Context",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.showContext",
        "title": "Show Active Context",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.addRepoToGroup",
        "title": "Add Repository to Group",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.removeRepoFromGroup",
        "title": "Remove Repository from Group",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.repoMenu",
        "title": "Repository Actions",
        "category": "CodeBrain"
      }
    ],
    "configuration": {
      "title": "CodeBrain",
      "properties": {
        "codebrain.autoSetupOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically run first-time CodeBrain CLI setup on workspace open."
        },
        "codebrain.autoIndex.onOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run analyze when opening a stale workspace."
        },
        "codebrain.autoIndex.onBranchChange": {
          "type": "boolean",
          "default": false,
          "description": "Automatically re-index when Git HEAD changes and the index is stale."
        },
        "codebrain.analyze.embeddings": {
          "type": "boolean",
          "default": false,
          "description": "Enable embedding generation during analyze (slower, better semantic search)."
        },
        "codebrain.stalenessCheckIntervalSeconds": {
          "type": "number",
          "default": 0,
          "description": "How often (seconds) to run automatic periodic re-index. Set 0 to disable."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codebrain",
          "title": "CodeBrain",
          "icon": "resources/icon-activity.svg"
        }
      ]
    },
    "views": {
      "codebrain": [
        {
          "id": "codebrain.quickActions",
          "name": "Quick Actions",
          "icon": "$(zap)"
        },
        {
          "id": "codebrain.groupsRepos",
          "name": "Repos & Groups",
          "icon": "$(server)"
        },
        {
          "id": "codebrain.agents",
          "name": "Copilot Agents",
          "icon": "$(robot)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codebrain.openDashboard",
          "when": "view == codebrain.quickActions",
          "group": "navigation@1"
        },
        {
          "command": "codebrain.refreshTreeView",
          "when": "view == codebrain.quickActions || view == codebrain.agents || view == codebrain.groupsRepos",
          "group": "navigation"
        }
      ],
      "scm/title": [
        {
          "command": "codebrain.prReview",
          "group": "codebrain@1"
        }
      ],
      "editor/context": [
        {
          "command": "codebrain.query",
          "group": "codebrain@1",
          "when": "editorTextFocus"
        }
      ],
      "view/item/context": [
        {
          "command": "codebrain.selectRepo",
          "when": "view == codebrain.groupsRepos && viewItem == repo",
          "group": "1_repo@1"
        },
        {
          "command": "codebrain.addRepoToGroup",
          "when": "view == codebrain.groupsRepos && viewItem == repo",
          "group": "1_repo@2"
        },
        {
          "command": "codebrain.selectGroup",
          "when": "view == codebrain.groupsRepos && viewItem == group",
          "group": "1_group@1"
        },
        {
          "command": "codebrain.removeRepoFromGroup",
          "when": "view == codebrain.groupsRepos && viewItem == repoInGroup",
          "group": "1_repoInGroup@1"
        }
      ],
      "commandPalette": [
        {
          "command": "codebrain.refreshTreeView",
          "when": "false"
        }
      ]
    },
    "chatSkills": [
      {
        "path": "./skills/gitnexus-query/SKILL.md"
      },
      {
        "path": "./skills/gitnexus-pr-review/SKILL.md"
      }
    ],
    "chatParticipants": [
      {
        "id": "codebrain.gitnexus",
        "name": "CodeBrain",
        "description": "Code-intelligence assistant powered by CodeBrain knowledge graph. Guides you through impact analysis, refactoring, debugging, and code exploration workflows.",
        "isSticky": true,
        "commands": [
          {
            "name": "impact",
            "description": "Run impact analysis on a symbol to assess blast radius"
          },
          {
            "name": "refactor",
            "description": "Get guided refactoring workflow"
          },
          {
            "name": "debug",
            "description": "Get guided debugging workflow"
          },
          {
            "name": "explain",
            "description": "Explore code and understand execution flows"
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build-icon": "node scripts/build-icon.mjs",
    "lint": "eslint src --ext ts",
    "build": "npm run build:deps && npm run build:ext",
    "build:deps": "npm run build:shared && npm run build:web && npm run bundle:cli",
    "build:shared": "cd GitNexus/gitnexus-shared && npm run build",
    "build:web": "cd GitNexus/gitnexus-web && npm run build",
    "build:ext": "npm run build-icon && npm run compile",
    "bundle:cli": "node scripts/copy-cli.mjs",
    "package": "vsce package --allow-missing-repository --skip-license --out codebrain-vscode.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "sharp": "^0.33.5",
    "typescript": "^5.4.0",
    "vsce": "^3.0.0"
  }
}
