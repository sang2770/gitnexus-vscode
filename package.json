{
  "name": "codebrain-vscode",
  "displayName": "CodeBrain",
  "description": "Repository-aware AI workflow orchestration for CodeGraph, Copilot Chat, and MCP.",
  "version": "2.0.1",
  "publisher": "codebrain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sang2770/gitnexus-vscode"
  },
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "icon": "resources/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "codebrain.setup",
        "title": "Setup CodeBrain Runtime",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.installCli",
        "title": "Prepare CodeGraph Runtime",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.createCopilotAgent",
        "title": "Create CodeBrain Copilot Agent",
        "category": "CodeBrain",
        "icon": "$(robot)"
      },
      {
        "command": "codebrain.checkForUpdates",
        "title": "Check for Extension Updates",
        "category": "CodeBrain",
        "icon": "$(cloud-download)"
      },
      {
        "command": "codebrain.tokenOptimization.selectMode",
        "title": "Set Token Optimization Mode",
        "category": "CodeBrain",
        "icon": "$(symbol-number)"
      },
      {
        "command": "codebrain.analyze",
        "title": "Analyze Workspace",
        "category": "CodeBrain",
        "icon": "$(graph-line)"
      },
      {
        "command": "codebrain.analyzeTreeItem",
        "title": "Analyze This Item",
        "category": "CodeBrain",
        "icon": "$(graph-line)"
      },
      {
        "command": "codebrain.analyzeForce",
        "title": "Force Re-index",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.status",
        "title": "Show Index Status",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.query",
        "title": "Query CodeGraph",
        "category": "CodeBrain",
        "icon": "$(search)"
      },
      {
        "command": "codebrain.prReview",
        "title": "Review Code with CodeBrain",
        "category": "CodeBrain",
        "icon": "$(git-pull-request-review)"
      },
      {
        "command": "codebrain.workflow.architecture",
        "title": "Workflow: Explain Architecture",
        "category": "CodeBrain",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "codebrain.workflow.explain",
        "title": "Workflow: Explain Current Flow",
        "category": "CodeBrain",
        "icon": "$(references)"
      },
      {
        "command": "codebrain.workflow.impact",
        "title": "Workflow: Analyze Impact",
        "category": "CodeBrain",
        "icon": "$(graph-line)"
      },
      {
        "command": "codebrain.workflow.review",
        "title": "Workflow: Review Changes",
        "category": "CodeBrain",
        "icon": "$(git-pull-request-review)"
      },
      {
        "command": "codebrain.workflow.test",
        "title": "Workflow: Generate Test Plan",
        "category": "CodeBrain",
        "icon": "$(beaker)"
      },
      {
        "command": "codebrain.workflow.detectChange",
        "title": "Workflow: Detect Change Impact",
        "category": "CodeBrain",
        "icon": "$(diff)"
      },
      {
        "command": "codebrain.workflow.plan",
        "title": "Workflow: Generate Plan",
        "category": "CodeBrain",
        "icon": "$(tasklist)"
      },
      {
        "command": "codebrain.impactLens.impact",
        "title": "Impact Lens: Analyze Impact",
        "category": "CodeBrain",
        "icon": "$(graph-line)"
      },
      {
        "command": "codebrain.impactLens.callers",
        "title": "Impact Lens: Find Callers",
        "category": "CodeBrain",
        "icon": "$(call-incoming)"
      },
      {
        "command": "codebrain.impactLens.callees",
        "title": "Impact Lens: Find Callees",
        "category": "CodeBrain",
        "icon": "$(call-outgoing)"
      },
      {
        "command": "codebrain.impactLens.affectedTests",
        "title": "Impact Lens: Find Affected Tests",
        "category": "CodeBrain",
        "icon": "$(beaker)"
      },
      {
        "command": "codebrain.impactLens.askCodeBrain",
        "title": "Impact Lens: Ask CodeBrain About Target",
        "category": "CodeBrain",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "codebrain.clean",
        "title": "Clean CodeGraph Index",
        "category": "CodeBrain"
      },
      {
        "command": "codebrain.refreshTreeView",
        "title": "Refresh",
        "category": "CodeBrain",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "CodeBrain",
      "properties": {
        "codebrain.autoSetupOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically run first-time CodeGraph setup on workspace open."
        },
        "codebrain.updateCheck.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically check GitHub releases for CodeBrain extension updates."
        },
        "codebrain.updateCheck.intervalHours": {
          "type": "number",
          "default": 24,
          "description": "Minimum hours between automatic GitHub release update checks."
        },
        "codebrain.autoIndex.onOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically sync CodeGraph when opening a stale workspace."
        },
        "codebrain.autoIndex.onBranchChange": {
          "type": "boolean",
          "default": false,
          "description": "Reserved for future branch-change auto-sync behavior."
        },
        "codebrain.stalenessCheckIntervalSeconds": {
          "type": "number",
          "default": 0,
          "description": "How often (seconds) to run automatic periodic CodeGraph sync. Set 0 to disable."
        },
        "codebrain.tokenOptimization.mode": {
          "type": "string",
          "enum": [
            "auto",
            "compact",
            "balanced",
            "full",
            "off"
          ],
          "default": "auto",
          "description": "Controls CodeBrain token optimization. Auto uses the workflow default; compact minimizes context, balanced keeps callers/dependencies, full preserves broader architecture context, off disables token reduction."
        },
        "codebrain.tokenOptimization.compactMaxTokens": {
          "type": "number",
          "default": 6000,
          "description": "Target token budget for compact CodeBrain context."
        },
        "codebrain.tokenOptimization.balancedMaxTokens": {
          "type": "number",
          "default": 12000,
          "description": "Target token budget for balanced CodeBrain context."
        },
        "codebrain.tokenOptimization.fullMaxTokens": {
          "type": "number",
          "default": 24000,
          "description": "Target token budget for full CodeBrain context."
        }
      }
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "codebrain.codegraph",
        "label": "CodeGraph"
      }
    ],
    "chatSkills": [
      {
        "path": "./skills/codegraph/SKILL.md"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codebrain",
          "title": "CodeBrain",
          "icon": "resources/icon-activity.svg"
        }
      ]
    },
    "views": {
      "codebrain": [
        {
          "id": "codebrain.quickActions",
          "name": "Quick Actions",
          "icon": "$(zap)"
        },
        {
          "id": "codebrain.impactLens",
          "name": "Impact Lens",
          "icon": "$(target)"
        },
        {
          "id": "codebrain.agents",
          "name": "Copilot Agents",
          "icon": "$(robot)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codebrain.refreshTreeView",
          "when": "view == codebrain.quickActions || view == codebrain.impactLens || view == codebrain.agents",
          "group": "navigation"
        }
      ],
      "scm/title": [
        {
          "command": "codebrain.prReview",
          "group": "codebrain@1"
        },
        {
          "command": "codebrain.workflow.detectChange",
          "group": "codebrain@2"
        }
      ],
      "editor/context": [
        {
          "command": "codebrain.workflow.explain",
          "group": "codebrain@1",
          "when": "editorTextFocus"
        },
        {
          "command": "codebrain.workflow.impact",
          "group": "codebrain@2",
          "when": "editorTextFocus"
        },
        {
          "command": "codebrain.workflow.plan",
          "group": "codebrain@3",
          "when": "editorTextFocus"
        },
        {
          "command": "codebrain.workflow.test",
          "group": "codebrain@4",
          "when": "editorTextFocus"
        },
        {
          "command": "codebrain.query",
          "group": "codebrain@5",
          "when": "editorTextFocus"
        },
        {
          "command": "codebrain.impactLens.impact",
          "group": "codebrain@6",
          "when": "editorTextFocus"
        },
        {
          "command": "codebrain.prReview",
          "group": "codebrain@7",
          "when": "editorTextFocus"
        }
      ],
      "commandPalette": [
        {
          "command": "codebrain.refreshTreeView",
          "when": "false"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "codebrain.codegraph",
        "name": "CodeBrain",
        "description": "Repository-aware workflow orchestration for CodeGraph retrieval, optional Atlassian context, context optimization, and Copilot Agent task generation.",
        "isSticky": true,
        "commands": [
          {
            "name": "architecture",
            "description": "Explain repository architecture with full-mode graph context"
          },
          {
            "name": "explain",
            "description": "Explain a symbol, flow, or file with compact graph context"
          },
          {
            "name": "impact",
            "description": "Analyze blast radius, callers, callees, and d-level risk"
          },
          {
            "name": "review",
            "description": "Review current changes with graph-aware context selection"
          },
          {
            "name": "test",
            "description": "Generate a focused test plan from affected code paths"
          },
          {
            "name": "detect_change",
            "description": "Detect working-tree change impact and validation scope"
          },
          {
            "name": "plan",
            "description": "Generate an implementation plan using CodeGraph plus optional Jira and collab context"
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build-icon": "node scripts/build-icon.mjs",
    "lint": "eslint src --ext ts",
    "build": "npm run build:deps && npm run build:ext",
    "build:deps": "npm run build:codegraph && npm run bundle:cli",
    "build:codegraph": "npm --prefix codegraph ci && npm --prefix codegraph run build",
    "build:ext": "npm run build-icon && npm run compile",
    "bundle:cli": "node scripts/copy-cli.mjs",
    "package": "npm run build && vsce package --allow-missing-repository --out codebrain-vscode.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.106.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "sharp": "^0.33.5",
    "typescript": "^5.4.0",
    "vsce": "*"
  },
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.22",
    "@sigma/edge-curve": "^3.1.0",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "sigma": "^3.0.3",
    "strip-ansi": "^7.2.0"
  }
}
